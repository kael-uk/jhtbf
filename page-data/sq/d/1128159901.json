931d35.jpg 1368w,\n/static/59f174cff39d686654c1467d42c85587/2bf3f/_3131931d35.jpg 2736w","sizes":"(min-width: 2736px) 2736px, 100vw"},"sources":[{"srcSet":"/static/59f174cff39d686654c1467d42c85587/4632f/_3131931d35.webp 684w,\n/static/59f174cff39d686654c1467d42c85587/b0358/_3131931d35.webp 1368w,\n/static/59f174cff39d686654c1467d42c85587/51c8b/_3131931d35.webp 2736w","type":"image/webp","sizes":"(min-width: 2736px) 2736px, 100vw"}]},"width":2736,"height":3648}}}}},{"title":"3966涤纶化学纤维用","id":"5099e9db-84cf-5f9c-8a00-a1f03b43c523","image":{"localFile":{"publicURL":"/static/ae81709718673f08a8835ceb206da492/3966_7e5e585f08.jpg","childImageSharp":{"gatsbyImageData":{"layout":"constrained","backgroundColor":"#b8b8b8","images":{"fallback":{"src":"/static/ae81709718673f08a8835ceb206da492/123de/3966_7e5e585f08.jpg","srcSet":"/static/ae81709718673f08a8835ceb206da492/85aae/3966_7e5e585f08.jpg 912w,\n/static/ae81709718673f08a8835ceb206da492/64308/3966_7e5e585f08.jpg 1824w,\n/static/ae81709718673f08a8835ceb206da492/123de/3966_7e5e585f08.jpg 3648w","sizes":"(min-width: 3648px) 3648px, 100vw"},"sources":[{"srcSet":"/static/ae81709718673f08a8835ceb206da492/fabd0/3966_7e5e585f08.webp 912w,\n/static/ae81709718673f08a8835ceb206da492/d2b65/3966_7e5e585f08.webp 1824w,\n/static/ae81709718673f08a8835ceb206da492/99098/3966_7e5e585f08.webp 3648w","type":"image/webp","sizes":"(min-width: 3648px) 3648px, 100vw"}]},"width":3648,"height":2736}}}}}]},"strapiCorporateProfile":{"content":{"data":{"content":"    江苏沪申钛白科技有限公司(原)上海江沪钛白制品有限公司是创始人谢益元先生1983年在湖南邵阳创办了湖南江沪实业有限公司，1990年迁移到上海;1992年正式成立上海江沪实业有限公司;因工厂的需要，投资了上海江沪钛白制品有限公司，接着谢益元先生研发的化学纤维用二氧化钛取得成功。2000年谢益元先生又相继研发了食品级二氧化钛和药品级二氧化钛，结束了该领域二氧化钛只能依靠进口的历史。\n\n2016年6月在江苏省通州湾江海联动开发示范区长江路210号购买土地近80亩，自建了51660m的6栋厂房和综合楼。并于2016年10月13日注册成立了江苏沪申钛白科技有限公司，注册资金10,000万元，核准生产和销售精细二氧化钛系列产品。公司继承了原上海公司已有的生产技术，为使二氧化钛精加工更加科学、合理，不断添置生产设备和检测仪器，现生产规模在原上海公司的基础上有大幅度提升，建有万级(C级)微生物检测及CNAS实验中心，已于2022年9月评审顺利通过。公司还组建了产品研发团队，确保不断有研发的新产品供应市场。\n\n江苏沪申钛白科技有限公司建有10万级(D级)标准空气净化药用辅料二氧化钛生产车间，年产量3000吨。\n\n江苏沪申钛白科技有限公司建有化学纤维用二氧化钛车间，生产用于涤纶、长丝、色母粒、氨纶、锦纶、粘胶、丙纶、腈纶和再生聚酯化纤的各种专用二氧化钛，年产量36,000吨，质量超出行业标准。\n\n江苏沪申钛白科技有限公司建有醋酸纤用二氧化钛的生产线，年产量为8000吨。公司建有电池用二氧化钛的生产线，年产量为5000吨。\n\n江苏沪申钛白科技有限公司建有食品添加剂二氧化钛专用车间，年产量5000吨。公司前身上海江沪钛白制品有限公司是《食品添加剂二氧化钛》国家标准的起草单位，公司创始人谢益元先生是该标准的主要起草人之一。公司建有食品添加剂氢氧化钙车间，年产量5000吨;复配着色剂(高分散型)车间，年产量1500吨;复配着色乳化剂车间，年产量1500吨;复配着色剂(A、B、C、D)车间，年产量1500吨，每个产品都有专用生产线。为进一步提升产品质量，2021年8月谢益元先生亲自设计现场指导投资新建一个精制二氧化钛车间，产能5000吨。\n\n江苏沪申钛白科技有限公司于2021年12月2日获得了江苏省科学技术厅、江苏省财政厅、国家税务总局江苏省税务局颁发的高新技术企业证书。\n\n为此我们公司全体员工真切希望广大新老客户一如既往支持我们，我们会以更优良的产品和诚信服务回报您们，并谨向您们表示真诚的感谢!\n\n欢迎广大新老客户来我公司光临指导!"}},"image":{"localFile":{"childImageSharp":{"gatsbyImageData":{"layout":"constrained","backgroundColor":"#b8b8b8","images":{"fallback":{"src":"/static/f5df38f98df0030e1f85fa9a0ccb05b9/d5ca8/Fo_T_Qn_Mr8_mtzgo_K41_Gi_YH_34_A1_Co_f6833662ef.jpg","srcSet":"/static/f5df38f98df0030e1f85fa9a0ccb05b9/9f76e/Fo_T_Qn_Mr8_mtzgo_K41_Gi_YH_34_A1_Co_f6833662ef.jpg 512w,\n/static/f5df38f98df0030e1f85fa9a0ccb05b9/63b16/Fo_T_Qn_Mr8_mtzgo_K41_Gi_YH_34_A1_Co_f6833662ef.jpg 1024w,\n/static/f5df38f98df0030e1f85fa9a0ccb05b9/d5ca8/Fo_T_Qn_Mr8_mtzgo_K41_Gi_YH_34_A1_Co_f6833662ef.jpg 2048w","sizes":"(min-width: 2048px) 2048px, 100vw"},"sources":[{"srcSet":"/static/f5df38f98df0030e1f85fa9a0ccb05b9/ef95c/Fo_T_Qn_Mr8_mtzgo_K41_Gi_YH_34_A1_Co_f6833662ef.webp 512w,\n/static/f5df38f98df0030e1f85fa9a0ccb05b9/49aa4/Fo_T_Qn_Mr8_mtzgo_K41_Gi_YH_34_A1_Co_f6833662ef.webp 1024w,\n/static/f5df38f98df0030e1f85fa9a0ccb05b9/48c91/Fo_T_Qn_Mr8_mtzgo_K41_Gi_YH_34_A1_Co_f6833662ef.webp 2048w","type":"image/webp","sizes":"(min-width: 2048px) 2048px, 100vw"}]},"width":2048,"height":1556}}}}},"allStrapiBanner":{"nodes":[{"image":{"localFile":{"publicURL":"/static/933391e35a799ec001ddd58d9746d91a/20230714012343_effa9a8a68.png","childImageSharp":{"gatsbyImageData":{"layout":"constrained","backgroundColor":"#080808","images":{"fallback":{"src":"/static/933391e35a799ec001ddd58d9746d91a/cb649/20230714012343_effa9a8a68.png","srcSet":"/sta