7fc6a3e503b748e0f6513b92c5e65/06b82/2023_b95f3a3ff7.jpg 4608w","sizes":"(min-width: 4608px) 4608px, 100vw"},"sources":[{"srcSet":"/static/88b7fc6a3e503b748e0f6513b92c5e65/2624c/2023_b95f3a3ff7.webp 1152w,\n/static/88b7fc6a3e503b748e0f6513b92c5e65/f47b5/2023_b95f3a3ff7.webp 2304w,\n/static/88b7fc6a3e503b748e0f6513b92c5e65/6a840/2023_b95f3a3ff7.webp 4608w","type":"image/webp","sizes":"(min-width: 4608px) 4608px, 100vw"}]},"width":4608,"height":3456}}}}]},{"desc":"江苏沪申钛白科技有限公司是由上海江沪实业有限公司、上海江沪钛白化工制品有限公司，上海凌升精制钛白粉有限公司一起合并重新在江苏南通投资兴办的，其下还包括江苏沪申药业有限公司，是食品添加剂二氧化钛国家标准主起草单位，拥有多品种二氧化钛研发生产能力，强大的检测分析能力，拥有国家CNAS认证的实验室。公司熟悉二氧化钛国内外产品特性和行业发展现状与进展，愿与行业内各方朋友助力行业健康发展，推动健康中国进一步落地。\n【供应类型】食品配料&添加剂\n【产品/服务】主营产品：\n食品添加剂二氧化钛、钛白粉、白色素、氢氧化钙、食品增白剂、复配着色乳化剂、高分散白色素。","id":"54adbdcc-3c1b-56e9-a825-83c948b4569e","time":"2023-09-20","title":"江苏沪申钛白科技有限公司相关证件","media":[{"localFile":{"publicURL":"/static/719babebd266361a3b10d6901d2b9787/20231104000944_f5b37728cd.jpg","childImageSharp":{"gatsbyImageData":{"layout":"constrained","backgroundColor":"#3888c8","images":{"fallback":{"src":"/static/719babebd266361a3b10d6901d2b9787/83eab/20231104000944_f5b37728cd.jpg","srcSet":"/static/719babebd266361a3b10d6901d2b9787/5b128/20231104000944_f5b37728cd.jpg 2091w,\n/static/719babebd266361a3b10d6901d2b9787/81095/20231104000944_f5b37728cd.jpg 4182w,\n/static/719babebd266361a3b10d6901d2b9787/83eab/20231104000944_f5b37728cd.jpg 8364w","sizes":"(min-width: 8364px) 8364px, 100vw"},"sources":[{"srcSet":"/static/719babebd266361a3b10d6901d2b9787/35542/20231104000944_f5b37728cd.webp 2091w,\n/static/719babebd266361a3b10d6901d2b9787/7ee28/20231104000944_f5b37728cd.webp 4182w,\n/static/719babebd266361a3b10d6901d2b9787/f0f6d/20231104000944_f5b37728cd.webp 8364w","type":"image/webp","sizes":"(min-width: 8364px) 8364px, 100vw"}]},"width":8364,"height":2578}}}}]}]},"strapiHotProduct":{"products":[{"title":"二氧化钛、白色素 ","id":"6e020924-11cc-57a8-8c0c-d232c9426657","strapi_id":12,"image":{"localFile":{"publicURL":"/static/81d7343ec52e2